# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this to .env on your production server (Render/Railway/etc.)
# NEVER commit production secrets to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=8080

# ============================================
# CORS Configuration
# ============================================
# For React Native CLI apps: Use * (React Native bypasses CORS)
CORS_ORIGIN=*

# Only restrict CORS if you're ALSO building a web app:
# Single domain: CORS_ORIGIN=https://admin.chhattisgarhshaadi.com
# Multiple domains: CORS_ORIGIN=https://admin.chhattisgarhshaadi.com,https://app.chhattisgarhshaadi.com

# Note: React Native mobile apps don't have CORS restrictions

# ============================================
# DATABASE (PostgreSQL - Neon)
# ============================================
DATABASE_URL="your-neon-pooled-connection-string"
DIRECT_URL="your-neon-direct-connection-string"
DATABASE_CONNECTION_LIMIT=10

# ============================================
# JWT TOKENS (CRITICAL: Use strong secrets in production)
# ============================================
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="your-production-access-secret-min-64-chars"
JWT_REFRESH_SECRET="your-production-refresh-secret-min-64-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ============================================
# FIREBASE (REQUIRED for Phone Auth & Push Notifications)
# ============================================
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="your-firebase-service-account-email"
FIREBASE_PRIVATE_KEY="your-firebase-private-key-with-newlines"

# ============================================
# CLOUDFLARE R2 STORAGE (REQUIRED for Production Media)
# ============================================
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_BUCKET_NAME="chhattisgarh-shaadi-media"
R2_REGION="auto"
R2_PUBLIC_URL="https://pub-<id>.r2.dev"

# ============================================
# RAZORPAY (Required for payments)
# ============================================
RAZORPAY_KEY_ID="rzp_live_xxxxx"
RAZORPAY_KEY_SECRET="your-live-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret-from-razorpay-dashboard"

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=5242880
MAX_PROFILE_PHOTOS=5

# ============================================
# RATE LIMITING (Stricter in production)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=warn
