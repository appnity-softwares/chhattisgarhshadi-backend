# ============================================
# CHHATTISGARH SHAADI BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Backend API for React Native CLI Mobile App
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=8080

# ============================================
# CORS (For Mobile App)
# ============================================
# Note: React Native doesn't have CORS restrictions like web browsers
# Use * in development, restrict in production if needed
CORS_ORIGIN=*

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Example: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/matrimony_db?sslmode=require

# ============================================
# JWT TOKENS (REQUIRED)
# ============================================
# Generate strong secrets: openssl rand -base64 32
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# FIREBASE CONFIGURATION (REQUIRED)
# ============================================
# Used for Phone Auth verification and Push Notifications
# Get from: Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================
# CLOUDFLARE R2 STORAGE (REQUIRED for Production)
# ============================================
# Get from R2 Dashboard -> Manage API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_REGION=auto

# Public URL (Custom Domain or R2.dev)
# Example: https://media.chhattisgarhshaadi.com
R2_PUBLIC_URL=


# ============================================
# RAZORPAY (OPTIONAL - for payments)
# ============================================
# If not configured, payment features will be disabled
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=



# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Maximum file sizes (in bytes)
MAX_FILE_SIZE=5242880
# Maximum profile photos per user
MAX_PROFILE_PHOTOS=5

# ============================================
# RATE LIMITING
# ============================================
# Requests per window (default: 100 requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
# Options: error, warn, info, debug
LOG_LEVEL=info